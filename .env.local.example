# Find your league ID in the URL when viewing your league on sleeper.com or in the app:
# sleeper.com/leagues/<THIS_NUMBER>/team
SLEEPER_LEAGUE_ID=123456789012345678

# Optional but recommended: Vercel automatically sends this as a Bearer token
# on cron requests, so /api/refresh can verify the call really came from
# Vercel Cron and not a random visitor. Set the same value in your Vercel
# project's Environment Variables.
CRON_SECRET=change-me
